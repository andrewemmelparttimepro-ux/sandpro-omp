# Copy to .env.release.local for local release verification.
# Do not commit .env.release.local.

# Production read-only smoke
SANDPRO_SMOKE_ADMIN_EMAIL=
SANDPRO_SMOKE_ADMIN_PASSWORD=
SANDPRO_SMOKE_MEMBER_EMAIL=
SANDPRO_SMOKE_MEMBER_PASSWORD=

# Staging/practice-copy testing
SANDPRO_STAGING_BASE_URL=
SANDPRO_E2E_EMAIL=
SANDPRO_E2E_PASSWORD=
SANDPRO_E2E_ALLOW_MUTATION=1

# Email/runtime
RESEND_API_KEY=
EMAIL_FROM=SandPro OMP <notifications@objectivetracker.net>
APP_BASE_URL=https://objectivetracker.net
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@objectivetracker.net

# Thrawn Scout objective starter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
AGENT_FEATURE_ENABLED=true
AGENT_WEB_SEARCH_ENABLED=true
VITE_AGENT_FEATURE_ENABLED=true
SANDPRO_AGENT_E2E=1

# Analytics
VITE_MICROSOFT_CLARITY_PROJECT_ID=

# Optional screenshot output folder
SANDPRO_EVIDENCE_DIR=docs/evidence
